{
  "manifest_version": 3,
  "name": "Notch",
  "version": "0.3.0",
  "description": "Frame.io-style video review for YouTube, Vimeo, Loom, Google Drive, and Dropbox — browse saved reviews anywhere; comment and draw on supported players.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Toggle Notch sidebar",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "clipboardWrite", "tabs", "activeTab"],
  "externally_connectable": {
    "matches": ["https://notch.video/*", "https://notch.so/*"]
  },
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["jspdf-bridge.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
