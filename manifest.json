{
  "manifest_version": 3,
  "name": "Notch",
  "version": "0.3.0",
  "description": "FrameIO-style video review for YouTube, Vimeo, Loom, Google Drive, and Dropbox. Comment on any supported video.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Notch",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "clipboardWrite", "tabs", "activeTab"],
  "externally_connectable": {
    "matches": ["https://notch.video/*", "https://notch.so/*"]
  },
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://youtube.com/*",
        "*://m.youtube.com/*",
        "*://music.youtube.com/*",
        "*://www.youtube-nocookie.com/*",
        "*://youtube-nocookie.com/*",
        "*://youtu.be/*",
        "*://vimeo.com/*",
        "*://www.vimeo.com/*",
        "*://player.vimeo.com/*",
        "*://loom.com/*",
        "*://www.loom.com/*",
        "*://*.loom.com/*",
        "*://drive.google.com/*",
        "*://docs.google.com/*",
        "*://dropbox.com/*",
        "*://www.dropbox.com/*",
        "*://m.dropbox.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
